	partition simulations = m
		mode: import
		source =
				let
				    Result = try
				        let
				            Source = AzureStorage.DataLake(StorageAccountUrl & "/" & ContainerName & "/simulations"),
				            Sorted = Table.Sort(Source, {{"Date modified", Order.Descending}})
				        in
				            Parquet.Document(Sorted{0}[Content])
				    otherwise
				        #table({"snapshotDateUtc", "simulationId", "displayName", "description", "status", "attackType", "attackTechnique", "createdDateTime", "launchDateTime", "completionDateTime", "lastModifiedDateTime", "isAutomated", "automationId", "durationInDays", "payloadId", "payloadDisplayName", "reportTotalUserCount", "reportCompromisedCount", "reportClickCount", "reportReportedCount", "createdById", "createdByDisplayName", "createdByEmail", "lastModifiedById", "lastModifiedByDisplayName", "lastModifiedByEmail"}, {})
				in
				    Result

	annotation PBI_ResultType = Table

