	partition trainings = m
		mode: import
		source =
				let
				    Result = try
				        let
				            Source = AzureStorage.DataLake(StorageAccountUrl & "/" & ContainerName & "/trainings"),
				            Sorted = Table.Sort(Source, {{"Date modified", Order.Descending}})
				        in
				            Parquet.Document(Sorted{0}[Content])
				    otherwise
				        #table({"snapshotDateUtc", "trainingId", "displayName", "description", "durationInMinutes", "source", "type", "availabilityStatus", "hasEvaluation", "lastModifiedDateTime", "createdById", "createdByDisplayName", "createdByEmail", "lastModifiedById", "lastModifiedByDisplayName", "lastModifiedByEmail"}, {})
				in
				    Result

	annotation PBI_ResultType = Table

