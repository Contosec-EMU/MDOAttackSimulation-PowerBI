	partition payloads = m
		mode: import
		source =
				let
				    Result = try
				        let
				            Source = AzureStorage.DataLake(StorageAccountUrl & "/" & ContainerName & "/payloads"),
				            Sorted = Table.Sort(Source, {{"Date modified", Order.Descending}})
				        in
				            Parquet.Document(Sorted{0}[Content])
				    otherwise
				        #table({"snapshotDateUtc", "payloadId", "displayName", "description", "simulationAttackType", "platform", "status", "source", "predictedCompromiseRate", "complexity", "technique", "theme", "brand", "industry", "isCurrentEvent", "isControversial", "lastModifiedDateTime", "createdById", "createdByDisplayName", "createdByEmail", "lastModifiedById", "lastModifiedByDisplayName", "lastModifiedByEmail"}, {})
				in
				    Result

	annotation PBI_ResultType = Table

