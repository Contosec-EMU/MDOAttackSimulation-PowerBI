	partition users = m
		mode: import
		source =
				let
				    Result = try
				        let
				            Source = AzureStorage.DataLake(StorageAccountUrl & "/" & ContainerName & "/users"),
				            Sorted = Table.Sort(Source, {{"Date modified", Order.Descending}})
				        in
				            Parquet.Document(Sorted{0}[Content])
				    otherwise
				        #table({"snapshotDateUtc", "userId", "displayName", "givenName", "surname", "mail", "department", "companyName", "city", "country", "jobTitle", "accountEnabled"}, {})
