	partition simulationUserEvents = m
		mode: import
		source =
				let
				    Result = try
				        let
				            Source = AzureStorage.DataLake(StorageAccountUrl & "/" & ContainerName & "/simulationUserEvents"),
				            Sorted = Table.Sort(Source, {{"Date modified", Order.Descending}})
				        in
				            Parquet.Document(Sorted{0}[Content])
				    otherwise
