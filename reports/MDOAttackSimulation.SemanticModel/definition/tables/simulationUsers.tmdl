	partition simulationUsers = m
		mode: import
		source =
				let
				    Result = try
				        let
				            Source = AzureStorage.DataLake(StorageAccountUrl & "/" & ContainerName & "/simulationUsers"),
				            Sorted = Table.Sort(Source, {{"Date modified", Order.Descending}})
				        in
				            Parquet.Document(Sorted{0}[Content])
				    otherwise
				        #table({"snapshotDateUtc", "simulationId", "userId", "email", "displayName", "compromisedDateTime", "reportedPhishDateTime", "assignedTrainingsCount", "completedTrainingsCount", "inProgressTrainingsCount", "isCompromised"}, {})
				in
				    Result

	annotation PBI_ResultType = Table

